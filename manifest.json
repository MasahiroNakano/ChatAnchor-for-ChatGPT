{
  "manifest_version": 3,
  "name": "ChatGPT Navigator + Scroll Lock",
  "version": "1.0.0",
  "description": "Adds previous/next user-message navigation and a scroll-lock toggle on chatgpt.com.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
